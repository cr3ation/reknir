# =============================================================================
# Database
# =============================================================================

# Separate credentials (used by docker-compose to create the database)
POSTGRES_USER=reknir
POSTGRES_PASSWORD=reknir         # IMPORTANT: Change in production!
POSTGRES_DB=reknir

# Full connection URL (postgres = service name in Docker network)
DATABASE_URL=postgresql://reknir:reknir@postgres:5432/reknir

# =============================================================================
# Backend
# =============================================================================

# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-in-production-to-a-random-string

# Set to False in production
DEBUG=True

# =============================================================================
# CORS – allowed origins for API requests
# =============================================================================

# Local access only
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Network access – add your server's IP (find with: hostname -I | awk '{print $1}')
# CORS_ORIGINS=http://192.168.1.100:5173,http://localhost:5173

# =============================================================================
# Frontend
# =============================================================================

# Local access
VITE_API_URL=http://localhost:8000/api

# Network access – replace with your server's IP
# VITE_API_URL=http://192.168.1.100:8000/api

# =============================================================================
# Backup (backup service in Docker)
# =============================================================================

BACKUP_KEEP_DAYS=2555  # 7 years per Swedish bookkeeping law
